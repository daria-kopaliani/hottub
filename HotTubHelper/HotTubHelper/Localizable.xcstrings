    "Add in the order shown. Wait at least 4 hours between major adjustments and re-test." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "In der gezeigten Reihenfolge zugeben. Zwischen größeren Anpassungen mindestens 4 Stunden warten und erneut testen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add in the order shown. Wait at least 4 hours between major adjustments and re-test." } },
