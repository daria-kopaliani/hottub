    "Consider a shock cycle if you haven't run one in the last few days.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erwäge eine Stoßbehandlung, falls in den letzten Tagen keine erfolgt ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Consider a shock cycle if you haven't run one in the last few days."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Considera un tratamiento de choque si no has hecho uno en los últimos días."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envisage un traitement choc si tu n'en as pas fait dans les derniers jours."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Valuta un trattamento shock se non ne hai fatto uno negli ultimi giorni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "数日間ショック処理を行っていない場合は、検討してください。"
          }
        }
      }
    },
