    },
    "Add in the order shown. Wait at least 4 hours between major adjustments and re-test.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In der gezeigten Reihenfolge zugeben. Zwischen größeren Anpassungen mindestens 4 Stunden warten und erneut testen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add in the order shown. Wait at least 4 hours between major adjustments and re-test."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade en el orden indicado. Espera al menos 4 horas entre ajustes importantes y vuelve a medir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute dans l'ordre indiqué. Attends au moins 4 heures entre les ajustements importants et remesure."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi nell'ordine indicato. Aspetta almeno 4 ore tra le regolazioni importanti e rimisura."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "表示の順序で追加してください。大きな調整の間は4時間以上待ち、再測定してください。"
          }
        }
      }
    },
    "Add the shock with the jets running for at least 15 minutes.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stoßmittel bei laufenden Düsen mindestens 15 Minuten zugeben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add the shock with the jets running for at least 15 minutes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade el producto de choque con los chorros encendidos al menos 15 minutos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute le produit choc avec les jets activés pendant au moins 15 minutes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi il prodotto shock con i getti accesi per almeno 15 minuti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ジェットを動かしながら、ショック剤を入れて少なくとも15分間運転します。"
          }
        }
      }
    },
    "Aerate the water for several hours after adding.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wasser nach der Zugabe mehrere Stunden belüften."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Aerate the water for several hours after adding."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Airea el agua durante varias horas tras la adición."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aère l'eau pendant plusieurs heures après l'ajout."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aera l'acqua per diverse ore dopo l'aggiunta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "追加後、数時間水を曝気してください。"
          }
        }
      }
    },
