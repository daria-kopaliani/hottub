    "Run the jets while adding. Re-test sanitizer level after 30–60 minutes.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Düsen beim Zugeben laufen lassen. Desinfektion nach 30–60 Minuten erneut testen."
          }
        },
        "en": {
