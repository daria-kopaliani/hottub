    "Shock breaks down body oils and bound sanitizer. The water may look cloudy briefly.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Stoßbehandlung baut Körperöle und gebundene Desinfektion ab. Das Wasser kann kurz trüb wirken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shock breaks down body oils and bound sanitizer. The water may look cloudy briefly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El tratamiento de choque elimina los aceites corporales y el desinfectante combinado. El agua puede verse turbia brevemente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le traitement choc dégrade les huiles corporelles et le désinfectant combiné. L'eau peut paraître trouble brièvement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo shock degrada gli oli corporei e il disinfettante legato. L'acqua può apparire torbida brevemente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショック処理は体油と結合塩素を分解します。水が一時的に濁ることがあります。"
          }
        }
      }
    },
