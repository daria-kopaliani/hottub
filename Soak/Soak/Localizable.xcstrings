    "Don't add more sanitizer. Let it dissipate — re-test in a few hours.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine weitere Desinfektion zugeben. Werte sinken lassen — in ein paar Stunden erneut testen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't add more sanitizer. Let it dissipate — re-test in a few hours."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No añadas más desinfectante. Deja que baje — vuelve a medir en unas horas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "N'ajoute pas plus de désinfectant. Laisse les valeurs baisser — remesure dans quelques heures."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non aggiungere altro disinfettante. Lascia che cali — rimisura tra qualche ora."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これ以上消毒剤を追加しないでください。自然に下がるのを待ち — 数時間後に再測定してください。"
          }
        }
      }
    },
